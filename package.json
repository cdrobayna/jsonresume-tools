{
  "name": "jsonresume-tools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A suite of independent tools for JSON Resume — starting with multi-locale parity checks and per-file quality linting.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "clean": "pnpm -r exec rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
