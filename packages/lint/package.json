{
  "name": "jsonresume-lint",
  "version": "0.1.1",
  "description": "Per-file quality checks for JSON Resume files: date formats, reverse chronology, URLs, email, leftover placeholders, and optional schema validation.",
  "keywords": [
    "json resume",
    "jsonresume",
    "resume",
    "cv",
    "lint",
    "validation"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "jsonresume-lint": "./dist/bin.js",
    "jrl": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && tsup"
  },
  "dependencies": {
    "@jsonresume/schema": "^1.3.0",
    "cosmiconfig": "^9.0.0"
  },
  "devDependencies": {
    "@jsonresume-tools/core": "workspace:*"
  }
}
