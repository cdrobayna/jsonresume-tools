{
  "name": "jsonresume-tailor",
  "version": "0.1.1",
  "description": "Generate role-tailored variants of a JSON Resume from a single annotated master resume.",
  "keywords": [
    "json resume",
    "jsonresume",
    "resume",
    "cv",
    "tailor",
    "variant"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "jsonresume-tailor": "./dist/bin.js"
  },
  "files": [
    "dist",
    "tailor-variant.schema.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && tsup"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "cosmiconfig": "^9.0.0"
  },
  "devDependencies": {
    "@jsonresume-tools/core": "workspace:*",
    "@jsonresume/schema": "^1.3.0"
  }
}
